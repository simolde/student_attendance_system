generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                   String               @id @default(cuid())
  name                 String?
  email                String               @unique
  password             String?
  role                 Role                 @default(STUDENT)
  isActive             Boolean              @default(true)
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  emailVerified        DateTime?
  image                String?
  mustChangePassword   Boolean              @default(false)
  accounts             Account[]
  announcements        Announcement[]
  announcementReads    AnnouncementRead[]
  auditLogs            AuditLog[]
  sessions             Session[]
  student              Student?
  studentImportBatches StudentImportBatch[] @relation("StudentImportBatchCreatedBy")
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  id                String  @id @default(cuid())
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  sessionToken String   @id @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}

model Section {
  id          String           @id @default(cuid())
  name        String           @unique
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  gradeLevel  GradeLevel
  rules       AttendanceRule[]
  enrollments Enrollment[]
  students    Student[]
}

model SchoolYear {
  id                   String               @id @default(cuid())
  name                 String               @unique
  isActive             Boolean              @default(false)
  startDate            DateTime?
  endDate              DateTime?
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  enrollments          Enrollment[]
  studentImportBatches StudentImportBatch[]
}

model Student {
  id            String              @id @default(cuid())
  userId        String              @unique
  studentNo     String              @unique
  sectionId     String?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  rfidUid       String?             @unique
  importBatchId String?
  attendances   Attendance[]
  enrollments   Enrollment[]
  rfidLogs      RfidLog[]
  importBatch   StudentImportBatch? @relation(fields: [importBatchId], references: [id])
  section       Section?            @relation(fields: [sectionId], references: [id])
  user          User                @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Enrollment {
  id           String           @id @default(cuid())
  studentId    String
  schoolYearId String
  sectionId    String
  status       EnrollmentStatus @default(ENROLLED)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  attendances  Attendance[]
  schoolYear   SchoolYear       @relation(fields: [schoolYearId], references: [id])
  section      Section          @relation(fields: [sectionId], references: [id])
  student      Student          @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, schoolYearId])
  @@index([schoolYearId, sectionId])
}

model Attendance {
  id           String           @id @default(cuid())
  studentId    String
  date         DateTime         @db.Date
  status       AttendanceStatus
  remarks      String?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  enrollmentId String?
  source       AttendanceSource @default(MANUAL)
  timeIn       DateTime?
  timeOut      DateTime?
  enrollment   Enrollment?      @relation(fields: [enrollmentId], references: [id])
  student      Student          @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, date])
  @@index([enrollmentId, date])
}

model RfidDevice {
  id         String    @id @default(cuid())
  name       String
  location   String?
  deviceCode String?   @unique
  isActive   Boolean   @default(true)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  rfidLogs   RfidLog[]
}

model RfidLog {
  id        String         @id @default(cuid())
  rfidUid   String
  studentId String?
  deviceId  String?
  scanTime  DateTime       @default(now())
  status    RfidScanStatus
  message   String?
  createdAt DateTime       @default(now())
  device    RfidDevice?    @relation(fields: [deviceId], references: [id])
  student   Student?       @relation(fields: [studentId], references: [id])

  @@index([rfidUid])
  @@index([studentId, scanTime])
}

model AuditLog {
  id          String   @id @default(cuid())
  userId      String?
  action      String
  entity      String
  entityId    String?
  description String?
  createdAt   DateTime @default(now())
  user        User?    @relation(fields: [userId], references: [id])
}

model AttendanceRule {
  id           String      @id @default(cuid())
  name         String      @unique
  timeInStart  String
  timeInEnd    String
  lateAfter    String
  timeOutStart String?
  timeOutEnd   String?
  isActive     Boolean     @default(true)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  gradeLevel   GradeLevel?
  isDefault    Boolean     @default(false)
  sectionId    String?
  section      Section?    @relation(fields: [sectionId], references: [id])

  @@index([gradeLevel, isActive])
  @@index([sectionId, isActive])
}

model StudentImportBatch {
  id                 String      @id @default(cuid())
  createdByUserId    String?
  schoolYearId       String?
  totalRows          Int         @default(0)
  createdUsers       Int         @default(0)
  createdStudents    Int         @default(0)
  createdEnrollments Int         @default(0)
  updatedUsers       Int         @default(0)
  updatedStudents    Int         @default(0)
  updatedEnrollments Int         @default(0)
  skipped            Int         @default(0)
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt
  isArchived         Boolean     @default(false)
  students           Student[]
  createdByUser      User?       @relation("StudentImportBatchCreatedBy", fields: [createdByUserId], references: [id])
  schoolYear         SchoolYear? @relation(fields: [schoolYearId], references: [id])

  @@index([createdAt])
  @@index([isArchived, createdAt])
}

model Announcement {
  id        String             @id @default(cuid())
  title     String
  content   String
  createdAt DateTime           @default(now())
  authorId  String?
  isPinned  Boolean            @default(false)
  status    AnnouncementStatus @default(PUBLISHED)
  targets   AnnouncementTarget[] @default([ALL])
  updatedAt DateTime           @updatedAt
  author    User?              @relation(fields: [authorId], references: [id])
  reads     AnnouncementRead[]

  @@index([status, createdAt(sort: Desc)])
  @@index([isPinned, createdAt(sort: Desc)])
}

model AnnouncementRead {
  id             String       @id @default(cuid())
  announcementId String
  userId         String
  readAt         DateTime     @default(now())
  announcement   Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([announcementId, userId])
  @@index([userId])
}

enum Role {
  SUPER_ADMIN
  ADMIN
  TEACHER
  STAFF
  STUDENT
}

enum EnrollmentStatus {
  ENROLLED
  DROPPED
  GRADUATED
  TRANSFERRED
  INACTIVE
}

enum AttendanceStatus {
  PRESENT
  LATE
  ABSENT
  EXCUSED
}

enum AttendanceSource {
  MANUAL
  RFID
  IMPORT
}

enum RfidScanStatus {
  MATCHED
  UNKNOWN_CARD
  DUPLICATE_SCAN
  DENIED
}

enum GradeLevel {
  PRE_NURSERY
  NURSERY
  KINDER
  GRADE_1
  GRADE_2
  GRADE_3
  GRADE_4
  GRADE_5
  GRADE_6
  GRADE_7
  GRADE_8
  GRADE_9
  GRADE_10
  GRADE_11
  GRADE_12
}

enum AnnouncementTarget {
  ALL
  TEACHER
  STUDENT
  ADMIN
}

enum AnnouncementStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}
